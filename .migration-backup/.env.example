# ============================================================================
# Nexus Golden Window Planner — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to Git

# ============================================================================
# REQUIRED: Database Connection
# ============================================================================
# MySQL format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/nexus

# ============================================================================
# REQUIRED: Session & Auth
# ============================================================================
# Used for signing session cookies
JWT_SECRET=your_jwt_secret_key_min_32_chars_long

# ============================================================================
# REQUIRED: Google OAuth 2.0 (for Calendar sync)
# ============================================================================
# Get these from Google Cloud Console
# See GOOGLE_CLOUD_SETUP.md for detailed instructions
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ============================================================================
# REQUIRED: Google Places API (for venue suggestions)
# ============================================================================
# Get this from Google Cloud Console
# See GOOGLE_CLOUD_SETUP.md for detailed instructions
VITE_GOOGLE_PLACES_KEY=your_google_places_api_key

# ============================================================================
# REQUIRED: App URL (for OAuth redirects)
# ============================================================================
# Local: http://localhost:3000
# Production: https://your-nexus-app.com
VITE_APP_URL=http://localhost:3000

# ============================================================================
# OPTIONAL: Manus Integration (If deploying on Manus)
# ============================================================================
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# ============================================================================
# OPTIONAL: Node Environment
# ============================================================================
NODE_ENV=development
